# ═══════════════════════════════════════════════════════
# RutGonLink — Biến Môi Trường
# Copy file này thành .env và điền giá trị thật
# ═══════════════════════════════════════════════════════

# ─── DATABASE ───
DATABASE_URL="postgresql://admin:password123@localhost:5432/rutgonlink_dev?schema=public"

# ─── REDIS ───
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── BACKEND (NestJS) ───
PORT=3001
JWT_SECRET=THAY_BANG_CHUOI_NGAU_NHIEN_DAI
JWT_REFRESH_SECRET=THAY_BANG_CHUOI_NGAU_NHIEN_KHAC
JWT_EXPIRES_IN=7d

# ─── GOOGLE AUTH ───
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ─── CLOUDFLARE TURNSTILE ───
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# ─── FRONTEND (NEXT_PUBLIC_ prefix để expose ra browser) ───
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
